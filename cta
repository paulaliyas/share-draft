// src/lib/gtm.ts

declare global {
    interface Window {
        dataLayer?: Record<string, unknown>[]
    }
}

export interface GTMEvent {
    event: string
    [key: string]: unknown
}

/** Low-level push. Everything goes through here. SSR-safe. */
export const pushToDataLayer = (data: GTMEvent): void => {
    if (typeof window === "undefined") return
    window.dataLayer = window.dataLayer || []
    window.dataLayer.push(data)
}

/** ---- Route tracking ---- */
export const trackPageView = (url: string): void => {
    pushToDataLayer({ event: "page_view", page_path: url })
}

/** ---- CTA tracking ---- */
export interface CtaClickPayload {
    ctaName: string
    ctaLocation?: string
    [key: string]: unknown
}

export const trackCtaClick = (payload: CtaClickPayload): void => {
    pushToDataLayer({
        event: "cta_click",
        ...payload,
        ctaLocation:
            payload.ctaLocation ??
            (typeof window !== "undefined"
                ? window.location.pathname
                : undefined),
    })
}




// src/components/analytics/RouteTracker.tsx
"use client"

import { useEffect } from "react"
import { usePathname, useSearchParams } from "next/navigation"
import { trackPageView } from "@/src/lib/gtm"

export function RouteTracker(): null {
    const pathname = usePathname()
    const searchParams = useSearchParams()

    useEffect(() => {
        const query = searchParams.toString()
        const url = query ? `${pathname}?${query}` : pathname
        trackPageView(url)
    }, [pathname, searchParams])

    return null
}


